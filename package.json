{
  "name": "attune-bridge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "node scripts/kill-port.js && next dev -p 3000",
    "dev:3001": "next dev -p 3001",
    "dev:fresh": "node scripts/kill-port.js && rm -rf .next && next dev -p 3000",
    "build": "pnpm run ci:generate && next build",
    "vercel-build": "pnpm exec prisma migrate deploy && pnpm run build",
    "start": "next start",
    "clean": "rm -rf .next",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "ci:generate": "pnpm exec prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "db:clone:prod-to-dev": "bash scripts/db/clone-prod-to-dev.sh",
    "env:check": "node scripts/env-sync.mjs check",
    "env:sync": "node scripts/env-sync.mjs sync",
    "env:sync:all": "node scripts/env-sync.mjs sync --targets local,development,production-local,vercel-development,vercel-production",
    "env:set": "node scripts/env-sync.mjs set",
    "env:push": "node scripts/env-sync.mjs push",
    "env:vercel:sync-keys": "node scripts/env-sync.mjs sync --targets vercel-development,vercel-production && node scripts/env-sync.mjs check",
    "env:vercel:push-dev": "node scripts/env-sync.mjs push --from development --targets vercel-development",
    "env:vercel:push-prod": "node scripts/env-sync.mjs push --from production-local --targets vercel-production",
    "gh:user:switch": "bash scripts/gh-repo-user-switch.sh",
    "auth:backfill-owner-users": "tsx scripts/backfill-owner-users.ts",
    "auth:backfill-owner-users:dry-run": "tsx scripts/backfill-owner-users.ts --dry-run",
    "scheduler:race-check": "tsx scripts/scheduler-claim-race-check.ts",
    "scheduler:expired-check": "tsx scripts/scheduler-expired-claim-check.ts",
    "scheduler:checks": "pnpm run scheduler:race-check && pnpm run scheduler:expired-check"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.1",
    "@prisma/client": "^6.6.0",
    "next": "15.2.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-qr-code": "^2.0.18",
    "resend": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.2.9",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
