generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                   String                       @id @default(cuid())
  name                 String
  email                String                       @unique
  subscriptionStatus   SubscriptionStatus           @default(TRIAL_ACTIVE)
  trialStartedAt       DateTime?
  trialEndsAt          DateTime?
  paidThrough          DateTime?
  autoRenewEnabled     Boolean                      @default(false)
  deactivatedAt        DateTime?
  instantEmailNeutral  Boolean                      @default(true)
  instantEmailNegative Boolean                      @default(true)
  smsNegativeEnabled   Boolean                      @default(false)
  alertPhone           String?
  quietHoursStart      String?
  quietHoursEnd        String?
  locations            Location[]
  memberships          BusinessMembership[]
  notificationEvents   NotificationEvent[]
  featureRequests      OwnerFeatureRequest[]
  featureRequestVotes  OwnerFeatureRequestVote[]
  validationEvents     ValidationEvent[]
  moduleSubscriptions  BusinessModuleSubscription[]
  schedulerContacts    SchedulerContact[]
  schedulerOffers      SchedulerOffer[]
  loyaltyPlaybooks     LoyaltyPlaybook[]
  loyaltyOffers        LoyaltyOffer[]
  loyaltyTemplates     LoyaltyTemplate[]
  loyaltyMessages      LoyaltyMessage[]
  loyaltyConversions   LoyaltyConversion[]
  contactProfiles      ContactProfile[]
  missedCallConfig     MissedCallConfig?
  missedCallEvents     MissedCallEvent[]
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([subscriptionStatus])
  @@index([trialEndsAt])
  @@index([paidThrough])
  @@index([autoRenewEnabled])
}

model ContactProfile {
  id                String                   @id @default(cuid())
  businessId        String
  fullName          String?
  email             String?
  phone             String?
  normalizedEmail   String?
  normalizedPhone   String?
  consentStatus     ContactConsentStatus    @default(UNKNOWN)
  channelPreference ContactChannelPreference @default(NONE)
  quietHoursStart   String?
  quietHoursEnd     String?
  source            ContactSource           @default(MANUAL)
  lastInteractionAt DateTime?
  business          Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([businessId, normalizedEmail])
  @@unique([businessId, normalizedPhone])
  @@index([businessId, consentStatus, updatedAt])
  @@index([businessId, channelPreference])
}

model User {
  id                  String               @id @default(cuid())
  clerkUserId         String?              @unique
  email               String               @unique
  systemRole          SystemRole           @default(USER)
  businessMemberships BusinessMembership[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([systemRole])
}

model BusinessMembership {
  id         String                 @id @default(cuid())
  userId     String
  businessId String
  role       BusinessMembershipRole @default(OWNER)
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedFeedback Feedback[]        @relation("FeedbackAssignment")
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([userId, businessId])
  @@index([businessId, role])
  @@index([userId, role])
}

model MissedCallConfig {
  id               String   @id @default(cuid())
  businessId       String   @unique
  twilioPhone      String   @unique
  autoReplyMessage String   @default("Hey - sorry we missed your call. How can we help?")
  isActive         Boolean  @default(true)
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([twilioPhone])
}

model MissedCallEvent {
  id                String              @id @default(cuid())
  businessId        String
  callerPhone       String
  twilioCallSid     String              @unique
  smsStatus         MissedCallSmsStatus @default(PENDING)
  providerMessageId String?
  errorMessage      String?
  replyForwardedAt  DateTime?
  business          Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt         DateTime            @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, callerPhone])
}

model BusinessModuleSubscription {
  id         String                   @id @default(cuid())
  businessId String
  module     AppModule
  status     ModuleSubscriptionStatus @default(INACTIVE)
  startedAt  DateTime?
  endsAt     DateTime?
  business   Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  @@unique([businessId, module])
  @@index([businessId, status])
  @@index([module, status])
}

model OwnerFeatureRequest {
  id         String   @id @default(cuid())
  businessId String
  ownerEmail String
  module     FeatureRequestModule @default(PLATFORM)
  status     FeatureRequestStatus @default(NEW)
  details    String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  votes      OwnerFeatureRequestVote[]
  createdAt  DateTime @default(now())

  @@index([businessId, status, module, createdAt])
  @@index([ownerEmail, createdAt])
}

model OwnerFeatureRequestVote {
  id               String              @id @default(cuid())
  businessId       String
  featureRequestId String
  ownerEmail       String
  featureRequest   OwnerFeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  business         Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())

  @@unique([featureRequestId, ownerEmail])
  @@index([businessId, featureRequestId, createdAt])
}

model Location {
  id               String            @id @default(cuid())
  businessId       String
  name             String
  slug             String            @unique
  reviewLink       String?
  googleReviewLink String?
  yelpReviewLink   String?
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  feedback         Feedback[]
  schedulerOffers  SchedulerOffer[]
  loyaltyMessages  LoyaltyMessage[]
  validationEvents ValidationEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([businessId])
}

model ValidationEvent {
  id         String    @id @default(cuid())
  event      String
  businessId String?
  locationId String?
  metadata   Json?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([event, createdAt])
  @@index([businessId, createdAt])
  @@index([locationId, createdAt])
}

model Feedback {
  id                 String              @id @default(cuid())
  locationId         String
  assignedMembershipId String?
  sentiment          Sentiment
  message            String?
  wantsFollowUp      Boolean             @default(false)
  followUpPreference FollowUpPreference?
  phone              String?
  customerEmail      String?
  customerName       String?
  status             FeedbackStatus      @default(NEW)
  recoveryOutcome    RecoveryOutcome?
  firstViewedAt      DateTime?
  firstRespondedAt   DateTime?
  resolvedAt         DateTime?
  nextFollowUpAt     DateTime?
  internalNotes      String?
  assignedMembership BusinessMembership? @relation("FeedbackAssignment", fields: [assignedMembershipId], references: [id], onDelete: SetNull)
  location           Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  notificationEvents NotificationEvent[]
  loyaltyMessages    LoyaltyMessage[]
  createdAt          DateTime            @default(now())

  @@index([locationId])
  @@index([createdAt])
  @@index([assignedMembershipId])
  @@index([status, recoveryOutcome, nextFollowUpAt])
}

model NotificationEvent {
  id                String              @id @default(cuid())
  feedbackId        String
  businessId        String
  channel           NotificationChannel
  status            NotificationStatus
  reason            String?
  providerMessageId String?
  errorMessage      String?
  feedback          Feedback            @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  business          Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt         DateTime            @default(now())

  @@index([feedbackId, createdAt])
  @@index([businessId, createdAt])
}

model SchedulerContact {
  id              String                   @id @default(cuid())
  businessId      String
  name            String
  phone           String
  isActive        Boolean                  @default(true)
  notes           String?
  optedInAt       DateTime?
  optedOutAt      DateTime?
  optedOutReason  String?
  lastMessagedAt  DateTime?
  business        Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  offerRecipients SchedulerOfferRecipient[]
  claimedOffers   SchedulerOffer[]         @relation("SchedulerOfferClaimedBy")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([businessId, phone])
  @@index([businessId, isActive])
}

model SchedulerOffer {
  id                String                   @id @default(cuid())
  businessId        String
  locationId        String?
  serviceLabel      String
  discountText      String
  startsAt          DateTime
  expiresAt         DateTime?
  status            SchedulerOfferStatus     @default(DRAFT)
  sentAt            DateTime?
  claimedAt         DateTime?
  claimedByContactId String?
  closedAt          DateTime?
  business          Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location          Location?                @relation(fields: [locationId], references: [id], onDelete: SetNull)
  claimedByContact  SchedulerContact?        @relation("SchedulerOfferClaimedBy", fields: [claimedByContactId], references: [id], onDelete: SetNull)
  recipients        SchedulerOfferRecipient[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([businessId, status, createdAt])
  @@index([locationId, createdAt])
}

model SchedulerOfferRecipient {
  id                String                    @id @default(cuid())
  offerId           String
  contactId         String
  claimToken        String                    @unique
  smsStatus         SchedulerRecipientSmsStatus @default(PENDING)
  providerMessageId String?
  smsErrorMessage   String?
  sentAt            DateTime?
  claimedAt         DateTime?
  offer             SchedulerOffer            @relation(fields: [offerId], references: [id], onDelete: Cascade)
  contact           SchedulerContact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt         DateTime                  @default(now())

  @@unique([offerId, contactId])
  @@index([offerId, smsStatus])
  @@index([contactId, createdAt])
}

model LoyaltyPlaybook {
  id               String                @id @default(cuid())
  businessId       String
  name             String
  type             LoyaltyPlaybookType
  status           LoyaltyPlaybookStatus @default(ACTIVE)
  audience         LoyaltyAudience
  trigger          LoyaltyTrigger
  delayHours       Int                   @default(48)
  suppressIfBooked Boolean               @default(true)
  offerId          String?
  templateId       String?
  startedAt        DateTime?
  endedAt          DateTime?
  business         Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  offer            LoyaltyOffer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)
  template         LoyaltyTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  messages         LoyaltyMessage[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([businessId, status])
  @@index([businessId, trigger, status])
  @@index([businessId, audience, status])
}

model LoyaltyOffer {
  id             String            @id @default(cuid())
  businessId     String
  name           String
  kind           LoyaltyOfferKind
  valueText      String
  validDays      Int               @default(14)
  code           String?
  maxRedemptions Int?
  isActive       Boolean           @default(true)
  business       Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  playbooks      LoyaltyPlaybook[]
  messages       LoyaltyMessage[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([businessId, isActive, createdAt])
}

model LoyaltyTemplate {
  id          String                  @id @default(cuid())
  businessId  String
  name        String
  category    LoyaltyTemplateCategory
  subject     String
  previewText String?
  body        String
  ctaLabel    String
  isDefault   Boolean                 @default(false)
  business    Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  playbooks   LoyaltyPlaybook[]
  messages    LoyaltyMessage[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([businessId, category, isDefault])
}

model LoyaltyMessage {
  id                String               @id @default(cuid())
  businessId        String
  locationId        String?
  playbookId        String?
  templateId        String?
  offerId           String?
  feedbackId        String?
  customerName      String?
  customerEmail     String?
  trackingToken     String               @unique @default(cuid())
  channel           LoyaltyChannel       @default(EMAIL)
  status            LoyaltyMessageStatus @default(PENDING)
  sendAfter         DateTime
  sentAt            DateTime?
  providerMessageId String?
  errorMessage      String?
  skipReason        String?
  business          Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location          Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  playbook          LoyaltyPlaybook?     @relation(fields: [playbookId], references: [id], onDelete: SetNull)
  template          LoyaltyTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  offer             LoyaltyOffer?        @relation(fields: [offerId], references: [id], onDelete: SetNull)
  feedback          Feedback?            @relation(fields: [feedbackId], references: [id], onDelete: SetNull)
  conversions       LoyaltyConversion[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([businessId, status, sendAfter])
  @@index([businessId, createdAt])
  @@index([feedbackId, createdAt])
  @@index([customerEmail, createdAt])
}

model LoyaltyConversion {
  id          String               @id @default(cuid())
  businessId  String
  messageId   String
  type        LoyaltyConversionType
  metadata    Json?
  convertedAt DateTime             @default(now())
  business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  message     LoyaltyMessage       @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, type])
  @@index([businessId, type, convertedAt])
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum FollowUpPreference {
  TEXT
  CALL
  EMAIL
}

enum FeedbackStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

enum RecoveryOutcome {
  SAVED
  UNSAVED
  ESCALATED
}

enum ContactConsentStatus {
  UNKNOWN
  OPTED_IN
  OPTED_OUT
}

enum ContactChannelPreference {
  NONE
  SMS
  EMAIL
  CALL
}

enum ContactSource {
  MANUAL
  FEEDBACK
  SCHEDULER
  LOYALTY
  MISSED_CALL
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

enum AppModule {
  FEEDBACK
  REVIEWS
  SCHEDULER
  LOYALTY
  MISSED_CALL_TEXTBACK
}

enum MissedCallSmsStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ModuleSubscriptionStatus {
  ACTIVE
  TRIAL
  INACTIVE
}

enum SchedulerOfferStatus {
  DRAFT
  SENT
  CLAIMED
  CLOSED
  EXPIRED
}

enum SchedulerRecipientSmsStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum SubscriptionStatus {
  TRIAL_ACTIVE
  ACTIVE_PAID
  INACTIVE_EXPIRED
  INACTIVE_CANCELED
}

enum FeatureRequestModule {
  REVIEWS
  SCHEDULER
  LOYALTY
  MISSED_CALL_TEXTBACK
  PLATFORM
}

enum FeatureRequestStatus {
  NEW
  UNDER_REVIEW
  ACCEPTED
  SHIPPED
  DECLINED
}

enum LoyaltyPlaybookStatus {
  ACTIVE
  PAUSED
}

enum LoyaltyPlaybookType {
  SECOND_VISIT_BOOSTER
  WE_MISS_YOU
  VIP_THANK_YOU
  SERVICE_RECOVERY
  CUSTOM
}

enum LoyaltyAudience {
  FIRST_TIME
  REPEAT
  LAPSED_30_DAYS
  HIGH_FREQUENCY
}

enum LoyaltyTrigger {
  FEEDBACK_POSITIVE
  FEEDBACK_NEUTRAL
  FEEDBACK_NEGATIVE
  LIFECYCLE_LAPSED_30_DAYS
}

enum LoyaltyOfferKind {
  FLAT_DISCOUNT
  FREE_ADD_ON
  PRIORITY_ACCESS
  CUSTOM
}

enum LoyaltyTemplateCategory {
  GREAT
  OKAY
  NOT_GOOD
  LAPSED
}

enum LoyaltyChannel {
  EMAIL
  SMS
}

enum LoyaltyMessageStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
  CANCELED
}

enum LoyaltyConversionType {
  BOOKING
  REVIEW
}

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum BusinessMembershipRole {
  OWNER
}
