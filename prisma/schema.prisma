generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  locations Location[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Location {
  id               String     @id @default(cuid())
  businessId       String
  name             String
  slug             String     @unique
  reviewLink       String?
  googleReviewLink String?
  yelpReviewLink   String?
  business         Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  feedback         Feedback[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([businessId])
}

model Feedback {
  id            String    @id @default(cuid())
  locationId    String
  sentiment     Sentiment
  message       String?
  wantsFollowUp Boolean   @default(false)
  followUpPreference FollowUpPreference?
  phone         String?
  customerEmail String?
  customerName  String?
  location      Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([locationId])
  @@index([createdAt])
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum FollowUpPreference {
  TEXT
  CALL
  EMAIL
}
